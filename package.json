{
  "name": "classcurio",
  "version": "1.0.0",
  "description": "ClassCurio \u2014 classroom assessment platform with lockdown browser, PDF/Word import, Excel + Word reports.",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server/server.js",
    "electron": "electron electron/main.js",
    "dev": "concurrently \"npm run start\" \"wait-on http://localhost:3000 && electron electron/main.js\"",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "author": "Bhavna Sharma",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "docx": "^8.5.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mammoth": "^1.7.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.1",
    "session-file-store": "^1.5.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.bhavna.classcurio",
    "productName": "ClassCurio",
    "publish": null,
    "files": [
      "electron/**/*",
      "package.json",
      "electron/icons/**/*"
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": "dmg",
      "icon": "electron/icons/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/icons/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "differentialPackage": false
    }
  }
}
